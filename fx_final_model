def tbl(headers: list, rows: list):
    cw = []
    for i, h in enumerate(headers):
        mx = len(str(h))
        for r in rows:
            mx = max(mx, len(str(r[i])))
        cw.append(mx + 2)
    sep = "+" + "+".join("-" * w for w in cw) + "+"
    fmt = lambda v: "|" + "|".join(str(x).center(w) for x, w in zip(v, cw)) + "|"
    print(sep); print(fmt(headers)); print(sep)
    for r in rows:
        print(fmt(r))
    print(sep)


